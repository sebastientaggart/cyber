//- Shared <head>. Page entries set pageTitle / pageDescription via `block variables`.
head
  meta(charset="UTF-8")
  meta(name="viewport" content="width=device-width, initial-scale=1.0")
  meta(name="description" content=pageDescription)
  meta(property="og:title" content=pageTitle)
  meta(property="og:description" content=pageDescription)
  title= pageTitle

  //- Google Fonts: Lato + Roboto + Material Icons
  link(rel="preconnect" href="https://fonts.googleapis.com")
  link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
  link(
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&family=Roboto:wght@300;400;500;700&family=Material+Icons&display=swap"
  )

  //- Bootstrap 5.3.0 CSS (jsdelivr + SRI from getbootstrap.com docs)
  link(
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM"
    crossorigin="anonymous"
  )

  //- Bootstrap Icons (used by footer socials in Phase 1)
  link(
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
  )

  //- Site stylesheet — Parcel resolves relative to the entry .pug at src/
  link(rel="stylesheet" href="./css/main.scss")

  //- Bootstrap JS bundle (Popper included), deferred
  script(
    defer
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz"
    crossorigin="anonymous"
  )

  //- Lunr.js — Phase 3 search runtime. Loaded globally; src/js/search.js reads window.lunr.
  //- Pages without a search box never call into it, so the cost is one cached HTTP request.
  script(
    defer
    src="https://cdn.jsdelivr.net/npm/lunr@2.3.9/lunr.min.js"
  )
